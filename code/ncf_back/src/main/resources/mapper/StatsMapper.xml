<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.ncfback.mapper.StatsMapper">

    <select id="countUsers" resultType="long">
        SELECT COUNT(*) FROM users
    </select>

    <select id="countItems" resultType="long">
        SELECT COUNT(*) FROM items
    </select>

    <select id="countInteractions" resultType="long">
        SELECT COUNT(*) FROM interactions
    </select>

    <select id="countTrainingSamples" resultType="long">
        SELECT COUNT(*) FROM training_samples
    </select>

</mapper>
